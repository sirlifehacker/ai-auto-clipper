# Core
APP_ENV=development
LOG_LEVEL=INFO
LOCAL_STATE_BACKEND=sqlite
DATABASE_URL=sqlite:///data/jobs/clipper.sqlite3

# Storage paths
DOWNLOADS_DIR=data/downloads
RAW_DIR=data/raw
INPUT_DIR=data/input
TRANSCRIPTS_DIR=data/transcripts
CLIPS_DIR=data/clips
PROCESSED_DIR=data/processed

# YouTube / video processing
YTDLP_COOKIES_FILE=
YTDLP_FORMAT=bv*[height<=720]+ba/best[height<=720]/best
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FFMPEG_VIDEO_CODEC=libx264
FFMPEG_PRESET=slow
FFMPEG_CRF=18
FFMPEG_AUDIO_BITRATE=192k
FFMPEG_FPS=30

# Transcription
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=auto
TRANSCRIPTION_PROVIDER=youtube_or_whisper

# AI analysis
AI_PROVIDER=gemini
ANALYZER_PROVIDER=mock
VIDEO_ANALYZER_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_SECONDS=2
GEMINI_USE_VERTEX=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
VERTEX_VIDEO_MODEL=gemini-2.5-flash
GCS_TEMP_BUCKET=
VIDEO_DIRECT_UPLOAD_MAX_MB=20
VIDEO_ANALYSIS_MAX_RETRIES=3
VIDEO_ANALYSIS_RETRY_DELAY_SECONDS=2

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_OAUTH_CLIENT_SECRET_FILE=

# Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Future MCP integrations
AFTER_EFFECTS_MCP_SERVER_URL=
